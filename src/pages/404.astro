---
import Layout from '@layouts/Common.astro'
import Header from '@landmarks/Header.astro'

import {Icon} from 'astro-icon/components'

import mainImage from '@images/boy-surprised.jpeg'

const title = 'Page Not Found'
---

<Layout {title}>
	<Header {title} {mainImage} />
	<section class="flex items-center justify-center text-center text-balance">
		<div class="text-lochmara-600 relative mb-6 flex justify-center">
			<Icon name="ph:compass-duotone" class="absolute size-24 opacity-20" />
			<p class="text-lochmara-600/10 text-9xl font-bold tracking-tight">404</p>
		</div>
		<h1 class="prose-sm">
			Oops! It looks like you went to the wrong classroom.
		</h1>
		<p class="mx-auto mt-6 max-w-md text-base leading-7 text-slate-600">
			Sorry, we couldn't find the page you're looking for. It might have moved,
			or perhaps it's taking a nap in the toddler room.
		</p>
		<div class="mt-10 flex items-center justify-center gap-x-6">
			<a href="/" class="btn">Back to Home</a>
			<a
				href="/contact"
				class="hover:text-lochmara-600 flex items-center gap-1 text-sm font-semibold text-slate-900 transition-colors">
				Contact Support <Icon name="ph:arrow-right" class="size-4" />
			</a>
		</div>
	</section>
</Layout>
