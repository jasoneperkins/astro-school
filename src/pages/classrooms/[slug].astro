---
export const prerender = true

import Layout from '@layouts/Common.astro'
import Header from '@landmarks/Header.astro'

import PortableTextCarousel from '@components/PortableTextCarousel.astro'

import {PortableText} from '@portabletext/react'
import {portableTextComponents} from '@lib/portableTextComponents'
import {fetchAllClassrooms, fetchClassroomBySlug} from '@lib/queries/classroom'

import '@styles/layouts/content.css'

export async function getStaticPaths() {
	const classrooms = await fetchAllClassrooms()
	return classrooms.map(classroom => ({
		// GraphQL returns slug as an object: { current: 'string' }
		params: {slug: classroom.slug.current}
	}))
}

const {slug} = Astro.params
const classroom = await fetchClassroomBySlug(slug)

if (!classroom) {
	return Astro.redirect('/404')
}

const title = classroom.title || 'Classroom'
// In GraphQL, we fetch the URL directly in the query
const mainImage = classroom.mainImage?.asset?.url || null
---

<Layout {title}>
	<Header {title} {mainImage} />

	<section class="content py-content-block bg-stone-50">
		{/* Overview / Philosophy Section */}
		<section class="max-w-4xl">
			<hgroup class="mb-6 flex flex-col-reverse">
				<h2 class="text-4xl font-bold text-stone-800">Our {title} Program</h2>
				{classroom.ageRange && <p class="tagline">Ages {classroom.ageRange}</p>}
			</hgroup>

			<div class="prose prose-stone lg:prose-xl text-stone-600">
				{/* Use PortableText for descriptionRaw from GraphQL */}
				{
					classroom.descriptionRaw && (
						<PortableText
							value={classroom.descriptionRaw}
							components={portableTextComponents}
						/>
					)
				}
			</div>
		</section>

		{/* Classroom Image Carousel */}
		{
			classroom.featuredCarousel && (
				<div class="breakout my-16">
					<PortableTextCarousel
						value={classroom.descriptionRaw}
						components={portableTextComponents}
					/>
				</div>
			)
		}

		{/* Day in the Life Schedule */}
		{
			classroom.dayInTheLife && (
				<section class="my-16">
					<h2 class="mb-8 text-3xl font-black text-stone-800">
						A Day in the Life
					</h2>
					<div class="grid gap-6 md:grid-cols-2">
						{classroom.dayInTheLife.map(item => (
							<div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-shadow hover:shadow-md">
								<h3 class="text-lochmara-600 text-xl font-bold">
									{item.activity}
								</h3>
								<p class="mt-2 leading-relaxed text-stone-600">
									{item.description}
								</p>
							</div>
						))}
					</div>
				</section>
			)
		}

		{/* Curriculum Highlights */}
		{
			classroom.curriculumHighlights && (
				<section class="bg-lochmara-900 my-16 rounded-3xl p-10 text-white shadow-xl">
					<h2 class="mb-8 text-3xl font-black">Curriculum Highlights</h2>
					<ul class="grid gap-6 md:grid-cols-2">
						{classroom.curriculumHighlights.map(highlight => (
							<li class="flex items-start gap-4">
								<span class="text-marigold-400 text-2xl">✨</span>
								<span class="text-lg font-medium opacity-95">{highlight}</span>
							</li>
						))}
					</ul>
				</section>
			)
		}
	</section>
</Layout>
