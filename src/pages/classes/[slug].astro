---
import {sanityClient} from 'sanity:client'
import {classroomQuery} from '@queries/classroom'
import {urlFor} from '@lib/urlFor'
import {formatDate} from '@utils/formatDate'
import Layout from '@layouts/Common.astro'
import Header from '@landmarks/Header.astro'
import VocabularyList from '@components/VocabularyList.astro'
import PortableTextCarousel from '@components/PortableTextCarousel.astro'
import {portableTextComponents} from '@lib/portableTextComponents'

import '@styles/layouts/content.css'

export async function getStaticPaths() {
	const classes = await sanityClient.fetch(
		`*[_type == "classroom"]{ "slug": slug.current }`
	)

	return classes.map(class => ({
		params: {class.slug}
	}))
}

const {slug} = Astro.params
const classroom = await sanityClient.fetch(classroomQuery, {slug})

if (!classroom) {
	return Astro.redirect('/404')
}

const title = classroom.title || 'Classroom'
const mainImage = classroom.classImage
	? urlFor(classroom.classImage).width(1600).height(900).url()
	: null
---

<Layout {title}>
	<Header {title} {mainImage} />

	<section class="content py-content-block">
		{/* Philosophy Section */}
		{
			classroom.philosophy && (
				<section class="prose prose-slate lg:prose-xl mb-12">
					<p class="lead">{classroom.philosophy}</p>
				</section>
			)
		}

		{/* Classroom Image Carousel */}
		{
			classroom.featuredCarousel && (
				<div class="my-12">
					<PortableTextCarousel
						value={newsletter.body}
						components={portableTextComponents}
					/>
				</div>
			)
		}

		{/* Day in the Life Schedule */}
		{
			classroom.dayInTheLife && (
				<section class="my-12">
					<h2 class="mb-6 text-3xl font-bold">A Day in the Life</h2>
					<div class="grid gap-6">
						{classroom.dayInTheLife.map(item => (
							<div class="rounded-2xl border border-slate-100 bg-slate-50 p-6">
								<h3 class="text-xl font-bold text-blue-700">{item.activity}</h3>
								<p class="mt-2 text-slate-700">{item.description}</p>
							</div>
						))}
					</div>
				</section>
			)
		}

		{/* Curriculum Highlights */}
		{
			classroom.curriculumHighlights && (
				<section class="my-12 rounded-3xl bg-blue-600 p-8 text-white shadow-xl">
					<h2 class="mb-6 text-3xl font-bold">Curriculum Highlights</h2>
					<ul class="grid gap-4 md:grid-cols-2">
						{classroom.curriculumHighlights.map(highlight => (
							<li class="flex items-center gap-3">
								<span class="text-2xl">✨</span>
								<span class="text-lg font-medium">{highlight}</span>
							</li>
						))}
					</ul>
				</section>
			)
		}
	</section>
</Layout>
