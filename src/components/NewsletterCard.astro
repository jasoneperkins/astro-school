---
import {urlFor} from '@lib/urlFor'
import {formatDate} from '@utils/formatDate'
import type {Newsletter} from '@sanity-types/sanity'

interface Props {
	newsletter: Newsletter
}

const {newsletter} = Astro.props
---

<article
	class="group relative flex flex-col overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition-all hover:shadow-md">
	<a href={`/newsletters/${newsletter.slug}`} class="flex h-full flex-col">
		{
			newsletter.mainImage ? (
				<div class="overflow-hidden">
					<img
						src={urlFor(newsletter.mainImage).width(600).height(400).url()}
						alt={newsletter.title}
						class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
						loading="lazy"
					/>
				</div>
			) : (
				<div class="flex aspect-video w-full items-center justify-center bg-slate-50 text-slate-400">
					<span class="text-xs font-semibold tracking-wider uppercase">
						TBH Learning Center
					</span>
				</div>
			)
		}

		<div class="flex flex-1 flex-col p-5">
			<header>
				<h2
					class="text-xl leading-tight font-bold text-gray-900 transition-colors group-hover:text-blue-700">
					{newsletter.title}
				</h2>
				<div class="mt-2 flex items-center text-sm text-gray-500">
					<time datetime={newsletter.publishedAt}>
						{formatDate(newsletter.publishedAt)}
					</time>
				</div>
			</header>

			{
				newsletter.excerpt && (
					<p class="mt-3 line-clamp-2 text-sm text-gray-600">
						{newsletter.excerpt}
					</p>
				)
			}

			<div class="mt-auto pt-4">
				<span class="text-sm font-semibold text-blue-600 group-hover:underline">
					Read Newsletter →
				</span>
			</div>
		</div>
	</a>
</article>
