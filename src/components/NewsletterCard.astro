---
import {formatDate} from '@utils/formatDate'
import type {Newsletter} from '@sanity-types/sanity'

interface Props {
	newsletter: Newsletter
}

const {newsletter} = Astro.props
const {publishedAt, slug, title, excerpt} = newsletter
---

<article
	class="group hover:border-lochmara-100 relative flex flex-col items-start rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition-all hover:shadow-md">
	<div class="mb-4 flex items-center gap-x-2 text-sm text-slate-500">
		<time datetime={publishedAt}>
			{formatDate(publishedAt)}
		</time>
	</div>

	<h2
		class="group-hover:text-lochmara-600 text-xl font-bold text-slate-900 transition-colors">
		<a href={`/newsletters/${slug}`}>
			<span class="absolute inset-0"></span>
			{title}
		</a>
	</h2>

	<p class="mt-3 line-clamp-3 text-slate-600">
		{excerpt || 'Stay updated with the latest happenings at Temple Beit HaYam.'}
	</p>

	<div class="text-lochmara-600 mt-6 flex items-center text-sm font-semibold">
		Read newsletter
		<svg
			class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1"
			fill="none"
			viewBox="0 0 24 24"
			stroke="currentColor">
			<path
				stroke-linecap="round"
				stroke-linejoin="round"
				stroke-width="2"
				d="M9 5l7 7-7 7">
			</path>
		</svg>
	</div>
</article>
