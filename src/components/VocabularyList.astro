---
interface Props {
	items: {
		word: string
		definition: string
	}[]
}

const {items = []} = Astro.params
---

<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
	{
		items.map(item => (
			<div class="hover:border-lochmara-300 rounded-xl border border-slate-200 bg-stone-50 p-6 transition-colors duration-200">
				<dt class="text-lochmara-700 mb-2 text-lg font-black tracking-wide uppercase">
					{item.word}
				</dt>
				<dd class="text-sm leading-relaxed text-stone-600">
					{item.definition}
				</dd>
			</div>
		))
	}
</div>

{
	!items.length && (
		<p class="text-stone-400 italic">No vocabulary terms added yet.</p>
	)
}
